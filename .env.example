MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aroma-cafe
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
PORT=5000
NODE_ENV=development

# Comma-separated list of origins allowed to call the API / connect via Socket.IO
CORS_ORIGIN=http://localhost:3000

# Used by the Next.js frontend (lib/auth/client.ts) to reach the Express API above
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- Firebase Admin SDK (backend, server.js / config/firebaseAdmin.js) ---
# From Firebase Console > Project settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# Paste the full private key. If your platform doesn't support real newlines in env
# values, keep the literal \n escapes -- config/firebaseAdmin.js converts them back.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# --- Firebase client SDK (frontend, lib/firebase/client.ts) ---
# From Firebase Console > Project settings > General > Your apps > Web app > SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
